# SafeGuard Environment Variables Example
# Copy this file to a new file named '.env' and fill in your API keys.

# Groq API Key (Used for emergency message responses and zero-shot classification)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (Used for vision analysis of photos/media files)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
